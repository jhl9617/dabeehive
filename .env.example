# Dabeehive Orchestrator PoC local environment
#
# Copy to .env or .env.local for local development only.
# Do not commit real secrets, API keys, tokens, or production URLs.

# Server / Prisma
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/dabeehive

# REST smoke script
# scripts/rest-happy-path-smoke.mjs defaults to http://127.0.0.1:18081.
DABEEHIVE_REST_BASE_URL=http://127.0.0.1:18081
DABEEHIVE_REST_OWNER_ID=demo-user
DABEEHIVE_REST_REQUESTED_BY_ID=demo-user

# MCP smoke script
# Use a local API token provisioned for the demo database.
DABEEHIVE_MCP_BASE_URL=http://127.0.0.1:18082/api/mcp
DABEEHIVE_MCP_TOKEN=<local-mcp-api-token>

# Agent SDK adapter
# Leave unset unless an approved local SDK task requires a real provider key.
ANTHROPIC_API_KEY=<anthropic-api-key>

# Optional Draft PR config
# Placeholders only. Do not commit real GitHub tokens.
DABEEHIVE_DRAFT_PR_GITHUB_OWNER=<github-owner>
DABEEHIVE_DRAFT_PR_GITHUB_REPO=<github-repo>
DABEEHIVE_DRAFT_PR_GITHUB_TOKEN=<github-token>
DABEEHIVE_DRAFT_PR_BASE_BRANCH=main

# VS Code Extension
# The extension server URL is configured through VS Code setting:
# dabeehive.serverUrl = http://127.0.0.1:3000
# API tokens are stored in VS Code SecretStorage, not in env files.
