{
  "name": "@dabeehive/vscode-extension",
  "version": "0.0.0",
  "private": true,
  "displayName": "Dabeehive Orchestrator",
  "description": "VS Code control surface for the Dabeehive AI Agent Orchestrator PoC.",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:dabeehive.refresh",
    "onCommand:dabeehive.setApiToken",
    "onCommand:dabeehive.clearApiToken",
    "onCommand:dabeehive.createIssue",
    "onCommand:dabeehive.startRun",
    "onCommand:dabeehive.openRunConsole",
    "onCommand:dabeehive.openApprovalPanel",
    "onView:dabeehive.views.issues",
    "onView:dabeehive.views.runs",
    "onView:dabeehive.views.approvals"
  ],
  "scripts": {
    "compile": "pnpm --filter @dabeehive/server exec tsc -p ../vscode-extension/tsconfig.json"
  },
  "contributes": {
    "commands": [
      {
        "command": "dabeehive.refresh",
        "title": "Dabeehive: Refresh",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.setApiToken",
        "title": "Dabeehive: Set API Token",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.clearApiToken",
        "title": "Dabeehive: Clear API Token",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.createIssue",
        "title": "Dabeehive: Create Issue",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.startRun",
        "title": "Dabeehive: Start Run",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.openRunConsole",
        "title": "Dabeehive: Open Run Console",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.openApprovalPanel",
        "title": "Dabeehive: Open Approval Panel",
        "category": "Dabeehive"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "dabeehive.startRun",
          "when": "view == dabeehive.views.issues && viewItem == dabeehive.issue",
          "group": "inline"
        },
        {
          "command": "dabeehive.openRunConsole",
          "when": "view == dabeehive.views.runs && viewItem == dabeehive.run",
          "group": "inline"
        },
        {
          "command": "dabeehive.openApprovalPanel",
          "when": "view == dabeehive.views.approvals && viewItem == dabeehive.approval",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dabeehive",
          "title": "Dabeehive",
          "icon": "resources/dabeehive.svg"
        }
      ]
    },
    "views": {
      "dabeehive": [
        {
          "id": "dabeehive.views.issues",
          "name": "Projects / Issues"
        },
        {
          "id": "dabeehive.views.runs",
          "name": "Runs"
        },
        {
          "id": "dabeehive.views.approvals",
          "name": "Approvals"
        }
      ]
    },
    "configuration": {
      "title": "Dabeehive",
      "properties": {
        "dabeehive.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "Base URL for the Dabeehive Orchestrator server."
        }
      }
    }
  }
}
