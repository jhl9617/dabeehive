{
  "name": "@dabeehive/vscode-extension",
  "version": "0.0.0",
  "private": true,
  "displayName": "Dabeehive Orchestrator",
  "description": "VS Code control surface for the Dabeehive AI Agent Orchestrator PoC.",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:dabeehive.refresh",
    "onCommand:dabeehive.setApiToken",
    "onCommand:dabeehive.clearApiToken",
    "onView:dabeehive.views.issues",
    "onView:dabeehive.views.runs",
    "onView:dabeehive.views.approvals"
  ],
  "scripts": {
    "compile": "pnpm --filter @dabeehive/server exec tsc -p ../vscode-extension/tsconfig.json"
  },
  "contributes": {
    "commands": [
      {
        "command": "dabeehive.refresh",
        "title": "Dabeehive: Refresh",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.setApiToken",
        "title": "Dabeehive: Set API Token",
        "category": "Dabeehive"
      },
      {
        "command": "dabeehive.clearApiToken",
        "title": "Dabeehive: Clear API Token",
        "category": "Dabeehive"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dabeehive",
          "title": "Dabeehive",
          "icon": "resources/dabeehive.svg"
        }
      ]
    },
    "views": {
      "dabeehive": [
        {
          "id": "dabeehive.views.issues",
          "name": "Issues"
        },
        {
          "id": "dabeehive.views.runs",
          "name": "Runs"
        },
        {
          "id": "dabeehive.views.approvals",
          "name": "Approvals"
        }
      ]
    },
    "configuration": {
      "title": "Dabeehive",
      "properties": {
        "dabeehive.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "Base URL for the Dabeehive Orchestrator server."
        }
      }
    }
  }
}
