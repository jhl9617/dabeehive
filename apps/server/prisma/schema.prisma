generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  role          String     @default("developer")
  apiTokens     ApiToken[]
  projects      Project[]  @relation("ProjectOwner")
  approvalRequests Approval[] @relation("ApprovalRequester")
  approvalResponses Approval[] @relation("ApprovalResponder")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  description   String?  @db.Text
  status        String   @default("draft")
  repoProvider  String?
  repoUrl       String?
  repoOwner     String?
  repoName      String?
  defaultBranch String?
  workspacePath String?
  owner         User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  issues        Issue[]
  documents     Document[]
  runs          AgentRun[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([repoOwner, repoName])
}

model Issue {
  id           String   @id @default(cuid())
  projectId    String
  parentId     String?
  title        String
  body         String?  @db.Text
  type         String   @default("task")
  status       String   @default("backlog")
  priority     String   @default("medium")
  assigneeRole String?
  labels       String[] @default([])
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Issue?   @relation("IssueHierarchy", fields: [parentId], references: [id])
  children     Issue[]  @relation("IssueHierarchy")
  runs         AgentRun[]
  approvals    Approval[]
  artifacts    Artifact[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([parentId])
  @@index([status])
  @@index([priority])
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  content   String   @db.Text
  version   Int      @default(1)
  status    String   @default("draft")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, type])
  @@index([status])
}

model AgentRun {
  id              String    @id @default(cuid())
  projectId       String
  issueId         String?
  status          String    @default("queued")
  agentRole       String
  modelProvider   String?
  modelId         String?
  inputContext    Json?
  outputSummary   String?   @db.Text
  outputArtifacts Json?
  errorMessage    String?   @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue           Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  events          RunEvent[]
  approvals       Approval[]
  artifacts       Artifact[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([issueId])
  @@index([status])
}

model RunEvent {
  id        String   @id @default(cuid())
  runId     String
  type      String
  message   String?  @db.Text
  metadata  Json?
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([runId, createdAt])
  @@index([type])
}

model Approval {
  id              String    @id @default(cuid())
  issueId         String?
  runId           String?
  requestedById   String?
  respondedById   String?
  type            String
  status          String    @default("pending")
  reason          String?   @db.Text
  changedFiles    String[]  @default([])
  diffSummary     String?   @db.Text
  riskScore       Int?
  requiredAction  String?   @db.Text
  issue           Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  run             AgentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  requester       User?     @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  responder       User?     @relation("ApprovalResponder", fields: [respondedById], references: [id], onDelete: SetNull)
  respondedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([issueId])
  @@index([runId])
  @@index([status])
  @@index([type])
  @@index([requestedById])
  @@index([respondedById])
}

model Artifact {
  id        String   @id @default(cuid())
  runId     String
  issueId   String?
  type      String
  title     String?
  content   String?  @db.Text
  uri       String?
  metadata  Json?
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@index([issueId])
  @@index([type])
  @@index([runId, type])
}
